C4Component
    title HAL Komponenten

    System(beaglebone_c_lib, "C Hardware Library", "C / arm-linux-gnueabihf-gcc", "Cross-kompilierte Shared Library (libhardware.so) mit Low-Level Hardware-Treibern")
    System(beaglebone_rust_lib, "Rust Hardware Library", "Rust / armv7-unknown-linux-musleabihf", "Cross-kompilierte Shared Library (libhardware_rs.so); Memory-Safe Alternative zur C-Lib")
    Container_Boundary(beaglebone_go_api, "REST API Server") {
        Component(beaglebone_go_api_api_handlers, "API Handler", "Go / Gorilla Mux", "HTTP-Handler für alle Endpunkte: /health, /api/v1/bme280, /api/v1/gpio, /api/v1/uart, /api/v1/spi, /api/v1/backend")
        Component(beaglebone_go_api_hal, "Hardware Abstraction Layer (HAL)", "Go Interface", "Definiert das HardwareDriver Interface; wählt Backend per HW_BACKEND Umgebungsvariable")
        Component(beaglebone_go_api_hal_hal_c, "C Driver", "Go / CGO", "Implementiert HardwareDriver via CGO-Bindings zur C-Bibliothek; höchste Performance")
        Component(beaglebone_go_api_hal_hal_factory, "Backend Factory", "Go", "Wählt C-, Rust- oder Auto-Backend anhand von HW_BACKEND (default: auto)")
        Component(beaglebone_go_api_hal_hal_mock, "Mock Driver", "Go", "Stub-Implementierung für Unit-Tests ohne echte Hardware")
        Component(beaglebone_go_api_hal_hal_rust, "Rust Driver", "Go / FFI", "Implementiert HardwareDriver via FFI-Bindings zur Rust-Bibliothek; Memory-Safety")
    }

    Rel(beaglebone_go_api_api_handlers, beaglebone_go_api_hal, "delegiert Hardware-Zugriff")
    Rel(beaglebone_go_api_hal_hal_factory, beaglebone_go_api_hal_hal_c, "wählt (HW_BACKEND=c)")
    Rel(beaglebone_go_api_hal_hal_factory, beaglebone_go_api_hal_hal_rust, "wählt (HW_BACKEND=rust)")
    Rel(beaglebone_go_api_hal_hal_c, beaglebone_c_lib, "CGO")
    Rel(beaglebone_go_api_hal_hal_rust, beaglebone_rust_lib, "FFI")
