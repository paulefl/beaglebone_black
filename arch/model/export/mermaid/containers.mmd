C4Component
    title Container-Sicht

    System(bbcli, "bbcli", "Go / Cobra", "Kommandozeilen-Tool für direkte API-Interaktion; Cross-compiled für Linux amd64/arm")
    System(bbgui, "bbgui", "Go / Fyne", "Desktop-GUI Anwendung mit grafischer Darstellung der Sensordaten")
    System(bbtui, "bbtui", "Go / BubbleTea", "Interaktives Terminal-UI für Echtzeit-Anzeige von Sensordaten")
    Person(developer, "Entwickler / Operator", "Entwickelt, baut und deployt das System; überwacht Hardware-Sensoren")
    System(webdashboard, "Web Dashboard", "HTML / JavaScript", "Browser-basiertes Dashboard für Sensor-Visualisierung und GPIO-Steuerung")
    System_Boundary(beaglebone, "BeagleBone Black Embedded SW") {
        System(beaglebone_c_lib, "C Hardware Library", "C / arm-linux-gnueabihf-gcc", "Cross-kompilierte Shared Library (libhardware.so) mit Low-Level Hardware-Treibern")
        Container(beaglebone_go_api, "REST API Server", "Go 1.22 / Gorilla Mux", "HTTP-Server auf Port 5000; verarbeitet Anfragen und delegiert an HAL")
        Component(beaglebone_hardware, "Hardware Interfaces", "BeagleBone Black GPIO / I2C / UART / SPI", "Physische Schnittstellen des TI AM335x Prozessors")
        System(beaglebone_rust_lib, "Rust Hardware Library", "Rust / armv7-unknown-linux-musleabihf", "Cross-kompilierte Shared Library (libhardware_rs.so); Memory-Safe Alternative zur C-Lib")
    }

    Rel(developer, bbcli, "bedient")
    Rel(developer, bbtui, "bedient")
    Rel(developer, bbgui, "bedient")
    Rel(developer, webdashboard, "öffnet")
    Rel(bbcli, beaglebone_go_api, "HTTP REST :5000")
    Rel(bbtui, beaglebone_go_api, "HTTP REST :5000")
    Rel(bbgui, beaglebone_go_api, "HTTP REST :5000")
    Rel(webdashboard, beaglebone_go_api, "HTTP REST :5000")
    Rel(beaglebone_go_api, beaglebone_c_lib, "CGO")
    Rel(beaglebone_go_api, beaglebone_rust_lib, "FFI")
    Rel(beaglebone_c_lib, beaglebone_hardware, "I2C read")
    Rel(beaglebone_rust_lib, beaglebone_hardware, "I2C read")
    Rel(developer, beaglebone, "make deploy (SCP + systemctl)")
