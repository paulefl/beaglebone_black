  "views": {
    "containers": {
      "title": "Container-Sicht",
      "scope": "beaglebone",
      "include": [
        "developer",
        "bbcli",
        "bbtui",
        "bbgui",
        "webdashboard",
        "beaglebone.*"
      ],
      "description": "Interne Struktur: REST API, C-Lib, Rust-Lib und Hardware-Interfaces",
      "layout": "layered"
    },
    "context": {
      "title": "Systemkontext",
      "include": [
        "developer",
        "bbcli",
        "bbtui",
        "bbgui",
        "webdashboard",
        "beaglebone"
      ],
      "description": "Überblick: BeagleBone Black System, Akteure und Client-Tools",
      "layout": "layered"
    },
    "full": {
      "title": "Vollständige Architektur",
      "include": [
        "**"
      ],
      "description": "Alle Elemente und Beziehungen des BeagleBone Black Systems",
      "layout": "layered"
    },
    "hal-components": {
      "title": "HAL Komponenten",
      "scope": "beaglebone.go-api",
      "include": [
        "beaglebone.go-api.*",
        "beaglebone.go-api.hal.*",
        "beaglebone.c-lib",
        "beaglebone.rust-lib"
      ],
      "description": "HAL-Schicht mit C Driver (CGO), Rust Driver (FFI), Mock Driver und Backend Factory",
      "layout": "layered"
    },
    "hardware": {
      "title": "Hardware-Sicht",
      "scope": "beaglebone",
      "include": [
        "beaglebone.go-api.hal.hal-c",
        "beaglebone.go-api.hal.hal-rust",
        "beaglebone.c-lib.*",
        "beaglebone.rust-lib.*",
        "beaglebone.hardware.*"
      ],
      "description": "Mapping der C/Rust-Treiber auf die physischen Hardware-Interfaces (BME280, GPIO, UART, SPI)",
      "layout": "layered"
    }
  }
}