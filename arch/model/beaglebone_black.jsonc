    },
    {
      "from": "beaglebone.c-lib.c-spi",
      "to": "beaglebone.hardware.hw-spi",
      "label": "spidev",
      "kind": "uses"
    },
    {
      "from": "beaglebone.rust-lib.rs-bme280",
      "to": "beaglebone.hardware.hw-bme280",
      "label": "I2C read",
      "kind": "uses"
    },
    {
      "from": "beaglebone.rust-lib.rs-gpio",
      "to": "beaglebone.hardware.hw-gpio",
      "label": "sysfs",
      "kind": "uses"
    },
    {
      "from": "beaglebone.rust-lib.rs-uart",
      "to": "beaglebone.hardware.hw-uart",
      "label": "serialport",
      "kind": "uses"
    },
    {
      "from": "beaglebone.rust-lib.rs-spi",
      "to": "beaglebone.hardware.hw-spi",
      "label": "spidev",
      "kind": "uses"
    },
    {
      "from": "developer",
      "to": "beaglebone",
      "label": "make deploy (SCP + systemctl)",
      "kind": "deploys"
    },
    {
      "from": "beaglebone.go-api.hal.hal-factory",
      "to": "beaglebone.go-api.hal.hal-c",
