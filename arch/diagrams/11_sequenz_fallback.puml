@startuml 11_sequenz_fallback
!theme plain
skinparam backgroundColor #060a10
skinparam defaultFontColor #94a3b8
skinparam defaultFontName "JetBrains Mono"
skinparam defaultFontSize 10
skinparam sequenceArrowThickness 1.5

skinparam participant {
  BackgroundColor #111c2a
  BorderColor #1e3048
  FontColor #e2e8f0
}
skinparam sequence {
  LifeLineBorderColor #1e3048
  ArrowColor #475569
  GroupBackgroundColor #0d1520
  GroupBorderColor #334155
}

title <color:#fb923c><b>Sequenzdiagramm — HAL Auto-Fallback</b></color>

participant "Go API" as API #022c22
participant "AutoDriver" as AUTO #431407
participant "C Driver\n(primär)" as CD #1e1b4b
participant "Rust Driver\n(sekundär)" as RD #2d1206
participant "libhardware\n.so (C)" as CL #111c2a
participant "libhardware_rs\n.so (Rust)" as RL #111c2a

API -> AUTO : BME280Read()
activate AUTO #431407

AUTO -> CD : primary.BME280Read()
activate CD #1e1b4b

CD -> CL : C.bme280_read()
activate CL #111c2a

note over CL
  <color:#ef4444>I2C Fehler!
  /dev/i2c-1 nicht erreichbar</color>
end note

CL --> CD : error: -2\n(I2C open failed)
deactivate CL

CD --> AUTO : error: "C BME280 fehlgeschlagen"
deactivate CD

note over AUTO
  <color:#f59e0b>Log: "C fehlgeschlagen → Rust Fallback"</color>
end note

AUTO -> RD : secondary.BME280Read()
activate RD #2d1206

RD -> RL : rs_bme280_read("/dev/i2c-1", 0x76)
activate RL #111c2a

RL --> RD : RsBme280Data\n{temp:23.45, error:0}
deactivate RL

RD --> AUTO : *BME280Data\nbackend: "rust"
deactivate RD

AUTO --> API : *BME280Data\n{temperature:23.45,\nbackend:"rust"}
deactivate AUTO

note right of API
  <color:#4ade80>Transparenter Fallback:
  Client sieht nur
  backend:"rust" im Response</color>
end note

@enduml
